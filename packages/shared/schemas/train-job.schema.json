{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gomoku.platform.train_job",
  "title": "TrainJob",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "jobId": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["queued", "running", "completed", "failed", "cancelled"]
    },
    "phase": {
      "type": "string"
    },
    "progress": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "createdAt": {
      "type": "string"
    },
    "updatedAt": {
      "type": "string"
    },
    "artifactId": {
      "type": "string"
    }
  },
  "required": ["jobId", "status", "createdAt", "updatedAt"]
}
