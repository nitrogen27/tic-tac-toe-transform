{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gomoku.platform.analyze_request",
  "title": "AnalyzeRequest",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "position": {
      "$ref": "./position.schema.json"
    },
    "topK": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "default": 5
    },
    "timeLimitMs": {
      "type": "integer",
      "minimum": 1,
      "maximum": 60000,
      "default": 1000
    },
    "includePv": {
      "type": "boolean",
      "default": true
    }
  },
  "required": ["position"]
}
