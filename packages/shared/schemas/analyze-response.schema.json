{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gomoku.platform.analyze_response",
  "title": "AnalyzeResponse",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "move": {
      "type": "integer",
      "minimum": -1,
      "maximum": 255
    },
    "value": {
      "type": "number",
      "minimum": -1,
      "maximum": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "source": {
      "type": "string"
    },
    "depth": {
      "type": "integer",
      "minimum": 0
    },
    "nodes": {
      "type": "integer",
      "minimum": 0
    },
    "timeMs": {
      "type": "integer",
      "minimum": 0
    },
    "pv": {
      "type": "array",
      "items": {
        "type": "integer",
        "minimum": 0,
        "maximum": 255
      }
    },
    "suggestions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "move": {
            "type": "integer",
            "minimum": 0,
            "maximum": 255
          },
          "score": {
            "type": "number"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "required": ["move", "score"]
      }
    }
  },
  "required": ["move", "value", "confidence", "source"]
}
