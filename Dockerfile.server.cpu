FROM node:20-slim

WORKDIR /app

COPY package.json package-lock.json* ./
COPY server/package.json ./server/

# CPU docker setup does not need the GPU package during install.
RUN npm pkg delete --workspace=server dependencies.@tensorflow/tfjs-node-gpu \
    && npm install --workspace=server

COPY server/ ./server/

RUN mkdir -p /app/server/saved

EXPOSE 8080

WORKDIR /app/server
CMD ["node", "server.mjs"]
